{
  "PRODUCT_START": {
    "switch": "!"
  },
  "PRODUCT_BEGIN": {
    "switch": "!"
  },
  "GAME_HOME": {
    "states": [
      "HOME",
      "POP"
    ],
    "exitevent": "event_hide_custom"
  },
  "GAME_HOME.POP": {
    "exitevent": "event_hide_custom"
  },
  "GAME_HOME.HOME": {
    "laterevent": "event_refresh_fakeMsg",
    "banner": {
      "switch": [
        "zs_home_banner_show_switch"
      ],
      "auto": true,
      "checkInit": true
    },
    "event": {
      "event_show_insertAd": [
        "zs_full_screen_ad",
        false
      ],
      "event_loadEnd_video": "zs_loading_video_switch",
      "event_backhome_video": "zs_start_video_switch",
      "event_backhome_custom": "event_backhome_custom",
      "event_show_custom": [
        [
          {
            "switch": [
              "zs_home_start_switch"
            ],
            "idKey": "zs_home_adunit",
            "centerX": 0,
            "top": 20,
            "width": 360
          },
          {
            "switch": [
              "zs_vertical_more_native_switch"
            ],
            "idKey": "zs_home_adunit_more1",
            "left": 30,
            "top": 500
          },
          {
            "switch": [
              "zs_vertical_more_native_switch"
            ],
            "idKey": "zs_home_adunit_more2",
            "right": 30,
            "top": 500
          }
        ]
      ]
    },
    "exitevent": "event_hide_custom",
    "exporter": [
      {
        "type": "export_side_native_center",
        "switch": [
          "zs_home_side_bar_switch",
          "zs_sidebar_native_switch"
        ],
        "window": {
          "align": "bottom",
          "alignoffsety": -450,
          "scale": [
            1,
            1
          ]
        },
        "base": {
          "customConfig": {
            "id": "zs_side_bar_adunit",
            "centerX": 0,
            "top": 400,
            "width": 330
          }
        }
      }
    ]
  },
  "PRODUCT_HOME_PLAY": {
    "states": [
      "VIDEO",
      "EGG"
    ],
    "exitevent": "event_hide_custom"
  },
  "PRODUCT_HOME_PLAY.VIDEO": {
    "switch": [
      "zs_switch",
      "zs_start_game_video_switch"
    ],
    "event": "event_start_video"
  },
  "PRODUCT_HOME_PLAY.EGG": {
    "laterevent": "event_refresh_fakeMsg",
    "check": {
      "event_check_egg": false
    },
    "base": {
      "type": "export_common_egg",
      "window": {
        "align": "topleft",
        "fit": true,
        "block": true
      },
      "base": {
        "awardevent": null,
        "closeevent": "event_childnext"
      }
    },
    "exitevent": "event_hide_custom"
  },
  "GAME_PLAY": {
    "states": [
      "NATIVE_1",
      "NATIVE_2",
      "NATIVE_3",
      "PLAY",
      "EGG",
      "BOX",
      "SETTLE",
      "END"
    ],
    "exitevent": "event_hide_custom"
  },
  "GAME_PLAY.NATIVE_1": {
    "check": {
      "event_check_full": 1
    },
    "event": {
      "event_show_custom": [
        [
          {
            "idKey": "zs_newly_adunit",
            "centerX": 0,
            "top": 300,
            "width": 330
          }
        ]
      ]
    },
    "base": [
      {
        "type": "export_background",
        "window": {
          "align": "topleft",
          "fit": true,
          "block": true
        },
        "base": {
          "alpha": 1,
          "color": "#426d8c"
        }
      },
      {
        "type": "export_button",
        "window": {
          "align": "bottom",
          "alignoffsety": -50
        },
        "base": {
          "switch": [
            "zs_switch",
            "zs_accidentally_touch_control"
          ],
          "clickignore": false,
          "firstclickignore": true,
          "width": 350,
          "height": 149,
          "fakeevent": {
            "event_show_banner": {
              "autoHide": true,
              "isFull": true
            }
          },
          "fakedelay": 1000,
          "event": "event_childnext",
          "url": [
            "export/export",
            "btn_GoOn"
          ]
        }
      }
    ],
    "exitevent": "event_hide_custom"
  },
